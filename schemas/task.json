{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "description": "A task to be executed by a remote node",
  "type": "object",
  "required": ["task_id", "task_type", "created_at", "created_by", "target_node", "status"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]{8}-[0-9]{4}$",
      "example": "task-20260324-0001"
    },
    "task_type": {
      "type": "string",
      "enum": ["analysis", "translation", "writing", "search", "custom"],
      "description": "Type of task"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "example": "chamberlain"
    },
    "target_node": {
      "type": "string",
      "example": "prime"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "accepted", "in_progress", "completed", "failed"],
      "default": "pending"
    },
    "input_ref": {
      "type": "string",
      "description": "Path or reference to input data"
    },
    "instructions": {
      "type": "string",
      "description": "Human-readable task instructions"
    }
  }
}
