{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Result",
  "description": "Result produced by a worker node after completing a task",
  "type": "object",
  "required": ["task_id", "status", "processed_at", "produced_by"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]{8}-[0-9]{4}$",
      "example": "task-20260324-0001"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "partial"]
    },
    "processed_at": {
      "type": "string",
      "format": "date-time"
    },
    "produced_by": {
      "type": "string",
      "example": "prime"
    },
    "summary": {
      "type": "string",
      "description": "Short structured result"
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Paths to output files"
    }
  }
}
